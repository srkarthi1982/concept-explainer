---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";
---

<AppShell title="Concept Explainer – Ansiversa" description="Write clear explanations for your concepts.">
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker"><span>Premium Learning · Ansiversa Mini App</span></div>
        <h1 class="av-gradient-text">Concept Explainer</h1>
        <p>Create your own simple explanations, examples, and notes for any topic.</p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Open App</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">Built for clear understanding</h2>
        <p class="av-section-lead">Capture concepts in your own words and review them with focus.</p>
      </div>
      <ul class="space-y-2 text-slate-300 list-disc list-inside">
        <li>Organize concepts by subject and topic.</li>
        <li>Highlight important concepts for quick revision.</li>
        <li>Archive old concepts while keeping your library tidy.</li>
      </ul>
    </AvContainer>
  </section>
</AppShell>
